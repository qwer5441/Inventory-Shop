*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.pdb
*.mdb

# 打包输出
*.apk
*.unitypackage
sysinfo.txt

# 系统垃圾文件
.DS_Store
Thumbs.db
Desktop.ini