# Unity缓存/临时文件（全部不上传）
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/

# 保留所有资源meta文件（丢meta会导致资源丢失）
!/[Aa]ssets/**/*.meta

# VS/Rider编辑器缓存
.vs/
.gradle/
/[Aa]ssets/Plugins/Editor/JetBrains*

